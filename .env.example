# Copy to .env and fill in values

# LLM backend: "ollama" (local, default) or "anthropic"
HERMES_BACKEND=ollama

# Ollama model — set to whichever model you have pulled locally
# Run `ollama list` to see available models
# Good options: qwen2.5-coder:7b, qwen2.5-coder:14b, qwen3-coder-next:cloud
HERMES_MODEL=qwen3-coder-next:cloud

# Ollama server URL (default is local)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Anthropic (only needed if HERMES_BACKEND=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Max investigative iterations before forcing synthesis (default 6)
# HERMES_MAX_ITER=6

# Default Postgres connection — pre-loaded as a built-in on every startup.
# If set, this becomes the default connection in the UI instead of the fixture DB.
# HERMES_DEFAULT_POSTGRES_DSN=postgresql://user:pass@localhost:5432/mydb

# SQL Knowledge Base — path to the folder containing SQL pattern and domain knowledge JSONs.
# When set, patterns are embedded into Qdrant and used to guide SQL generation and self-correction.
# HERMES_KB_PATH=/absolute/path/to/SQL KB JSONS
# HERMES_KB_ENABLED=true   # set to "false" to disable without removing the path
